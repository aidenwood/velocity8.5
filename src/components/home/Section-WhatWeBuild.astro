---
interface ProjectType {
  title: string;
  subtitle: string;
  description: string;
  image: string;
  link: string;
  span: string;
}

const projects: ProjectType[] = [
  {
    title: 'Marketing Sites',
    subtitle: 'Brand-first design',
    description: 'High-converting landing pages and brand websites built with our Velocity framework. Perfect Lighthouse scores, blazing load times.',
    image: '/works/ax-sqr-snacks.webp',
    link: '/web-design/velocity',
    span: 'md:col-span-2 md:row-span-2',
  },
  {
    title: 'E-Commerce',
    subtitle: 'Shopify & custom stores',
    description: 'Custom Shopify themes and headless commerce builds designed for conversion rate optimisation.',
    image: '/works/ax-sqr-estemshop.webp',
    link: '/web-design/shopify',
    span: 'md:col-span-1 md:row-span-1',
  },
  {
    title: 'Interactive Ads',
    subtitle: 'HTML5 & rich media',
    description: 'Animated display ads and interactive campaign assets built with GSAP and Canvas.',
    image: '/works/ax-sqr-interactive.webp',
    link: '/digital-marketing/interactive-ads',
    span: 'md:col-span-1 md:row-span-1',
  },
  {
    title: 'SaaS Dashboards',
    subtitle: 'Full-stack applications',
    description: 'React + Supabase applications with real-time data, auth, and complex UI. From internal tools to customer-facing platforms.',
    image: '/works/app-design.webp',
    link: '/web-design',
    span: 'md:col-span-1 md:row-span-2',
  },
  {
    title: 'Landing Pages',
    subtitle: 'Conversion-optimised',
    description: 'A/B tested, CRO-focused landing pages that turn ad traffic into leads and sales.',
    image: '/works/ax-sqr-golden.webp',
    link: '/web-design/velocity',
    span: 'md:col-span-1 md:row-span-1',
  },
  {
    title: 'Brand Identity',
    subtitle: 'Complete design systems',
    description: 'Logo, typography, colour, and collateral -- a cohesive brand system from digital to print.',
    image: '/works/complete-brand-pack.webp',
    link: '/graphic-design',
    span: 'md:col-span-1 md:row-span-1',
  },
];
---

<section class="my-28">
  <div class="mx-auto px-4 sm:px-6 w-full lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-8">

      <div class="flex flex-col gap-4 max-w-3xl">
        <h2 class="text-base lg:text-lg uppercase font-thin tracking-widest">
          What We Build
        </h2>
        <h3 class="text-3xl sm:text-4xl md:text-5xl font-medium tracking-tight">
          Every digital touchpoint, covered.
        </h3>
        <p class="text-primary-950/80 dark:text-primary-200/80 text-lg xs:text-xl">
          From first impression to final conversion. We design and build the full spectrum of digital products your business needs to compete.
        </p>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-5">
        {projects.map((project) => (
          <a
            href={project.link}
            class:list={[
              'group relative overflow-hidden rounded-2xl border border-primary-900/10 dark:border-primary-300/10',
              'transition-all duration-300 hover:border-primary-500/30 dark:hover:border-primary-400/30',
              'hover:shadow-lg hover:shadow-primary-500/10 dark:hover:shadow-primary-400/10',
              project.span,
            ]}
          >
            <!-- Background Image -->
            <div class="absolute inset-0">
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent" />
            </div>

            <!-- Content overlay -->
            <div class="relative flex flex-col justify-end p-5 sm:p-6 min-h-[240px] md:min-h-[280px]">
              <p class="text-xs uppercase tracking-widest text-primary-300 font-thin mb-2">
                {project.subtitle}
              </p>
              <h4 class="text-xl sm:text-2xl font-medium text-white tracking-tight mb-2">
                {project.title}
              </h4>
              <p class="text-sm text-white/60 leading-relaxed line-clamp-2">
                {project.description}
              </p>
              <div class="mt-3 flex items-center gap-2 text-primary-300 text-sm font-medium">
                <span>View work</span>
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
