---
interface ProcessStep {
  step: string;
  title: string;
  description: string;
  icon: string;
  accent: string;
}

const steps: ProcessStep[] = [
  {
    step: '01',
    title: 'Discover',
    description: 'Deep-dive into your brand, audience, competitors, and goals. We research your niche and map out what winning looks like.',
    icon: 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z',
    accent: 'from-primary-500 to-primary-700',
  },
  {
    step: '02',
    title: 'Design',
    description: 'Wireframes, prototypes, and high-fidelity mockups. Every pixel reviewed in person on the Gold Coast. No surprises at launch.',
    icon: 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
    accent: 'from-cyan-500 to-cyan-700',
  },
  {
    step: '03',
    title: 'Develop',
    description: 'Custom code, not templates. Built with our Velocity framework for 100/100 performance scores and rock-solid SEO foundations.',
    icon: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5',
    accent: 'from-green-500 to-green-700',
  },
  {
    step: '04',
    title: 'Launch & Grow',
    description: 'Deploy, monitor, iterate. Ongoing SEO, marketing management, and performance optimisation to keep you ahead of the pack.',
    icon: 'M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z',
    accent: 'from-primary-400 to-primary-600',
  },
];
---

<section class="my-28">
  <div class="mx-auto px-4 sm:px-6 w-full lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-8">

      <div class="flex flex-col gap-4 max-w-3xl">
        <h2 class="text-base lg:text-lg uppercase font-thin tracking-widest">
          How It Works
        </h2>
        <h3 class="text-3xl sm:text-4xl md:text-5xl font-medium tracking-tight">
          A process built for results.
        </h3>
        <p class="text-primary-950/80 dark:text-primary-200/80 text-lg xs:text-xl">
          Four focused phases. In-person collaboration on the Gold Coast. No handoffs to juniors, no template swaps disguised as custom work.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-4">

        <!-- Connector line (desktop only) -->
        <div class="hidden lg:block absolute top-16 left-[12.5%] right-[12.5%] h-[2px] bg-gradient-to-r from-primary-500/40 via-cyan-500/40 to-green-500/40" aria-hidden="true"></div>

        {steps.map((step) => (
          <div class="group relative flex flex-col gap-5 border border-primary-900/10 dark:border-primary-300/10 rounded-2xl p-6 sm:p-8 hover:bg-primary-900/5 dark:hover:bg-primary-300/5 transition-all duration-300 hover:border-primary-500/30 dark:hover:border-primary-400/30">

            <!-- Step number & icon circle -->
            <div class="relative flex items-center gap-4">
              <div class:list={[
                'flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br',
                step.accent,
                'shadow-lg group-hover:scale-110 transition-transform duration-300',
              ]}>
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                </svg>
              </div>
              <span class="text-3xl font-medium text-primary-300/50 dark:text-primary-600/50 tracking-tight">{step.step}</span>
            </div>

            <h4 class="text-xl sm:text-2xl font-medium tracking-tight text-primary-950 dark:text-white">
              {step.title}
            </h4>

            <p class="text-primary-950/70 dark:text-primary-200/70 text-base leading-relaxed">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
