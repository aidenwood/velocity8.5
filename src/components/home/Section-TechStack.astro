  { name: 'Google Ads', category: 'Marketing', accent: '#4285F4' },
  { name: 'Google Maps', category: 'API', accent: '#34A853' },
  { name: 'BigQuery', category: 'Data', accent: '#4285F4' },
  { name: 'Pipedrive', category: 'CRM', accent: '#017737' },
  { name: 'Shopify', category: 'Commerce', accent: '#96BF48' },
  { name: 'WordPress', category: 'CMS', accent: '#21759B' },
  { name: 'Python', category: 'Data', accent: '#3776AB' },
