---
/* Discovery Call Hero — sells the paid call */
---

<section class="pt-12 pb-8 sm:pt-16 sm:pb-12">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-start lg:items-center gap-12 lg:gap-16">

      <div class="w-full lg:w-3/5 flex flex-col gap-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center rounded-full bg-green-500/10 dark:bg-green-400/10 px-3 py-1 text-sm font-medium text-green-700 dark:text-green-300 ring-1 ring-inset ring-green-600/20 dark:ring-green-400/20">
            Limited Availability
          </span>
        </div>

        <h1 class="text-xs md:text-base uppercase font-thin tracking-widest">
          Work directly with Aiden Wood
        </h1>
        <h2 class="font-medium tracking-tighter md:tracking-tight text-4xl lg:text-5xl xl:text-6xl max-w-3xl">
          Book a Paid Discovery Call
        </h2>
        <p class="text-primary-950/80 dark:text-primary-200/80 text-lg xs:text-xl max-w-2xl">
          Skip the back-and-forth. Get expert eyes on your project in a focused,
          structured strategy session. Come prepared, leave with a clear action plan
          and technical recommendations tailored to your business.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-2">
          <a
            href="#booking"
            class="bg-primary-600 dark:bg-primary-400 hover:bg-primary-700 dark:hover:bg-primary-300 focus-visible:outline-primary-600 dark:focus-visible:outline-primary-400 dark:text-primary-950 inline-flex items-center justify-center rounded-full border border-transparent px-6 py-3.5 text-base font-medium text-white transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
          >
            Book Your Call
          </a>
          <a
            href="/web-design/previous-work/ball-realty"
            class="inline-flex items-center justify-center rounded-full border border-primary-300 dark:border-primary-700 px-6 py-3.5 text-base font-medium text-primary-900 dark:text-primary-100 transition hover:bg-primary-100 dark:hover:bg-primary-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
          >
            See Previous Work
          </a>
        </div>
      </div>

      <div class="w-full lg:w-2/5">
        <div class="border border-primary-900/10 dark:border-primary-300/10 bg-primary-500/5 dark:bg-primary-400/5 rounded-3xl p-8 flex flex-col gap-6">
          <h3 class="text-2xl font-medium tracking-tight">What You Get</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="text-primary-600 dark:text-primary-400 h-6 w-6 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM11.0026 16L18.0737 8.92893L16.6595 7.51472L11.0026 13.1716L8.17421 10.3431L6.75999 11.7574L11.0026 16Z"/>
              </svg>
              <div>
                <span class="font-medium">Full project audit & strategy</span>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60 mt-1">Technical review of your current site, competitors, and opportunities</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="text-primary-600 dark:text-primary-400 h-6 w-6 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM11.0026 16L18.0737 8.92893L16.6595 7.51472L11.0026 13.1716L8.17421 10.3431L6.75999 11.7574L11.0026 16Z"/>
              </svg>
              <div>
                <span class="font-medium">Custom recommendations document</span>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60 mt-1">Walk away with a written action plan, not just verbal advice</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="text-primary-600 dark:text-primary-400 h-6 w-6 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM11.0026 16L18.0737 8.92893L16.6595 7.51472L11.0026 13.1716L8.17421 10.3431L6.75999 11.7574L11.0026 16Z"/>
              </svg>
              <div>
                <span class="font-medium">Direct access to a senior developer</span>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60 mt-1">10+ years experience in web design, full-stack development & SEO</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="text-primary-600 dark:text-primary-400 h-6 w-6 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM11.0026 16L18.0737 8.92893L16.6595 7.51472L11.0026 13.1716L8.17421 10.3431L6.75999 11.7574L11.0026 16Z"/>
              </svg>
              <div>
                <span class="font-medium">Credit toward project booking</span>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60 mt-1">Discovery call fee is deducted from any project you book within 30 days</p>
              </div>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>
