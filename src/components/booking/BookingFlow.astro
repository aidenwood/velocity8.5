---
/* Full-screen step-by-step booking flow — each step fits within 100vh */
/* Alpine.js multi-step with 6 micro-steps */

/*
 * Stripe IDs (live):
 * Strategy Call $299 — price_1TPJXbI6j3bRmHwkE8hayq9A / prod_UO5jyW2zaKWtb8
 * Deep Dive $499    — price_1TPJXxI6j3bRmHwkW5Z3tkiQ / prod_UO5j8ykTGTDExx
 * Publishable key:    pk_live_51Mc3tdI6j3bRmHwkdDBpXfr9TQZVgvVToaYDLbensav3FydJtI2vt2V941EsNovfFynbCitFYrdwXWM4IK2Cjp6M00nIfYsj8W
 */
---

<section id="booking">
  <div
    x-data="{
      step: 1,
      totalSteps: 6,
      selectedCall: '',
      selectedPrice: '',
      selectedName: '',
      stripeLink: '',
      name: '',
      email: '',
      business: '',
      website: '',
      brief: '',
      next() { if (this.step < this.totalSteps) this.step++ },
      prev() { if (this.step > 1) this.step-- },
    }"
  >

    <!-- Step 1: Choose session -->
    <div
      x-show="step === 1"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="min-h-[100dvh] flex flex-col items-center justify-center px-4 sm:px-6"
    >
      <div class="w-full max-w-2xl flex flex-col gap-6">
        <div class="text-center">
          <span class="text-xs uppercase tracking-widest text-primary-500 dark:text-primary-400 font-medium">Step 1 of 6</span>
          <h2 class="text-3xl sm:text-4xl font-medium tracking-tight mt-3">Choose your session</h2>
          <p class="text-primary-950/60 dark:text-primary-200/60 mt-2">Credited toward any project booked within 30 days.</p>
        </div>

        <button
          type="button"
          x-on:click="selectedCall = 'strategy'; selectedPrice = '$299'; selectedName = 'Strategy Call — 30 min'; stripeLink = 'https://buy.stripe.com/REPLACE_WITH_STRATEGY_LINK'; next()"
          class="text-left flex items-center justify-between rounded-2xl border border-primary-900/10 dark:border-primary-300/10 p-5 sm:p-6 transition-all duration-200 hover:bg-primary-500/10 dark:hover:bg-primary-400/10 hover:border-primary-500/30"
        >
          <div>
            <h3 class="text-lg font-medium">Strategy Call</h3>
            <p class="text-sm text-primary-950/60 dark:text-primary-200/60 mt-1">30 min — focused session on a specific challenge</p>
          </div>
          <div class="text-right flex-shrink-0 ml-4">
            <span class="text-2xl font-medium">$299</span>
            <span class="text-xs text-primary-950/50 dark:text-primary-200/50 block">+ GST</span>
          </div>
        </button>

        <button
          type="button"
          x-on:click="selectedCall = 'deep-dive'; selectedPrice = '$499'; selectedName = 'Deep Dive — 60 min'; stripeLink = 'https://buy.stripe.com/REPLACE_WITH_DEEPDIVE_LINK'; next()"
          class="relative text-left flex items-center justify-between rounded-2xl border border-primary-600/30 dark:border-primary-400/30 bg-primary-500/5 dark:bg-primary-400/5 p-5 sm:p-6 transition-all duration-200 hover:bg-primary-500/10 dark:hover:bg-primary-400/10"
        >
          <span class="absolute -top-2.5 left-5 inline-flex items-center rounded-full bg-primary-600 dark:bg-primary-400 px-2.5 py-0.5 text-[11px] font-semibold text-white dark:text-primary-950">Recommended</span>
          <div>
            <h3 class="text-lg font-medium">Deep Dive</h3>
            <p class="text-sm text-primary-950/60 dark:text-primary-200/60 mt-1">60 min — full audit, competitor analysis & roadmap</p>
          </div>
          <div class="text-right flex-shrink-0 ml-4">
            <span class="text-2xl font-medium">$499</span>
            <span class="text-xs text-primary-950/50 dark:text-primary-200/50 block">+ GST</span>
          </div>
        </button>
      </div>
    </div>

    <!-- Step 2: Name + Email -->
    <div
      x-show="step === 2"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="min-h-[100dvh] flex flex-col items-center justify-center px-4 sm:px-6"
    >
      <div class="w-full max-w-md flex flex-col gap-6">
        <div class="text-center">
          <span class="text-xs uppercase tracking-widest text-primary-500 dark:text-primary-400 font-medium">Step 2 of 6</span>
          <h2 class="text-3xl sm:text-4xl font-medium tracking-tight mt-3">Who are you?</h2>
        </div>

        <div>
          <label for="b-name" class="block text-sm font-medium mb-1.5">Your Name</label>
          <input id="b-name" type="text" x-model="name" placeholder="Jane Smith"
            class="w-full px-4 py-3.5 border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 rounded-xl outline-none focus:ring-2 focus:ring-primary-500 dark:focus:ring-primary-400 transition text-lg" />
        </div>
        <div>
          <label for="b-email" class="block text-sm font-medium mb-1.5">Email</label>
          <input id="b-email" type="email" x-model="email" placeholder="you@company.com"
            class="w-full px-4 py-3.5 border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 rounded-xl outline-none focus:ring-2 focus:ring-primary-500 dark:focus:ring-primary-400 transition text-lg" />
        </div>

        <div class="flex justify-between mt-2">
          <button type="button" x-on:click="prev()" class="text-sm text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-200 transition">Back</button>
          <button type="button" x-on:click="if (name && email) next()"
            :class="(name && email) ? 'bg-primary-600 dark:bg-primary-400 dark:text-primary-950 text-white hover:bg-primary-700 dark:hover:bg-primary-300' : 'bg-primary-200 dark:bg-primary-800 text-primary-400 cursor-not-allowed'"
            class="rounded-full px-6 py-3 text-sm font-medium transition">
            Continue
          </button>
        </div>
      </div>
    </div>

    <!-- Step 3: Business + Website -->
    <div
      x-show="step === 3"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="min-h-[100dvh] flex flex-col items-center justify-center px-4 sm:px-6"
    >
      <div class="w-full max-w-md flex flex-col gap-6">
        <div class="text-center">
          <span class="text-xs uppercase tracking-widest text-primary-500 dark:text-primary-400 font-medium">Step 3 of 6</span>
          <h2 class="text-3xl sm:text-4xl font-medium tracking-tight mt-3">Your business</h2>
        </div>

        <div>
          <label for="b-biz" class="block text-sm font-medium mb-1.5">Business Name</label>
          <input id="b-biz" type="text" x-model="business" placeholder="Your Company"
            class="w-full px-4 py-3.5 border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 rounded-xl outline-none focus:ring-2 focus:ring-primary-500 dark:focus:ring-primary-400 transition text-lg" />
        </div>
        <div>
          <label for="b-web" class="block text-sm font-medium mb-1.5">Current Website <span class="text-primary-400">(optional)</span></label>
          <input id="b-web" type="url" x-model="website" placeholder="https://example.com"
            class="w-full px-4 py-3.5 border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 rounded-xl outline-none focus:ring-2 focus:ring-primary-500 dark:focus:ring-primary-400 transition text-lg" />
        </div>

        <div class="flex justify-between mt-2">
          <button type="button" x-on:click="prev()" class="text-sm text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-200 transition">Back</button>
          <button type="button" x-on:click="if (business) next()"
            :class="business ? 'bg-primary-600 dark:bg-primary-400 dark:text-primary-950 text-white hover:bg-primary-700 dark:hover:bg-primary-300' : 'bg-primary-200 dark:bg-primary-800 text-primary-400 cursor-not-allowed'"
            class="rounded-full px-6 py-3 text-sm font-medium transition">
            Continue
          </button>
        </div>
      </div>
    </div>

    <!-- Step 4: Project Brief -->
    <div
      x-show="step === 4"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="min-h-[100dvh] flex flex-col items-center justify-center px-4 sm:px-6"
    >
      <div class="w-full max-w-lg flex flex-col gap-6">
        <div class="text-center">
          <span class="text-xs uppercase tracking-widest text-primary-500 dark:text-primary-400 font-medium">Step 4 of 6</span>
          <h2 class="text-3xl sm:text-4xl font-medium tracking-tight mt-3">What do you need?</h2>
          <p class="text-primary-950/60 dark:text-primary-200/60 mt-2">This is sent to me before the call so I can prepare.</p>
        </div>

        <div>
          <textarea id="b-brief" x-model="brief" rows="4"
            placeholder="What are you looking to build or improve? What's your biggest challenge right now?"
            class="w-full px-4 py-3.5 border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 rounded-xl outline-none focus:ring-2 focus:ring-primary-500 dark:focus:ring-primary-400 transition text-lg resize-none"
          ></textarea>
        </div>

        <div class="flex justify-between mt-2">
          <button type="button" x-on:click="prev()" class="text-sm text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-200 transition">Back</button>
          <button type="button" x-on:click="if (brief) next()"
            :class="brief ? 'bg-primary-600 dark:bg-primary-400 dark:text-primary-950 text-white hover:bg-primary-700 dark:hover:bg-primary-300' : 'bg-primary-200 dark:bg-primary-800 text-primary-400 cursor-not-allowed'"
            class="rounded-full px-6 py-3 text-sm font-medium transition">
            Continue
          </button>
        </div>
      </div>
    </div>

    <!-- Step 5: Review -->
    <div
      x-show="step === 5"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="min-h-[100dvh] flex flex-col items-center justify-center px-4 sm:px-6"
    >
      <div class="w-full max-w-lg flex flex-col gap-6">
        <div class="text-center">
          <span class="text-xs uppercase tracking-widest text-primary-500 dark:text-primary-400 font-medium">Step 5 of 6</span>
          <h2 class="text-3xl sm:text-4xl font-medium tracking-tight mt-3">Look right?</h2>
        </div>

        <div class="border border-primary-900/10 dark:border-primary-300/10 bg-primary-500/5 dark:bg-primary-400/5 rounded-2xl p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-center justify-between pb-4 border-b border-primary-900/10 dark:border-primary-300/10">
            <span class="font-medium" x-text="selectedName"></span>
            <span class="text-xl font-medium" x-text="selectedPrice + ' + GST'"></span>
          </div>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div>
              <span class="text-primary-950/40 dark:text-primary-200/40">Name</span>
              <p class="font-medium" x-text="name"></p>
            </div>
            <div>
              <span class="text-primary-950/40 dark:text-primary-200/40">Email</span>
              <p class="font-medium" x-text="email"></p>
            </div>
            <div>
              <span class="text-primary-950/40 dark:text-primary-200/40">Business</span>
              <p class="font-medium" x-text="business"></p>
            </div>
            <div>
              <span class="text-primary-950/40 dark:text-primary-200/40">Website</span>
              <p class="font-medium" x-text="website || '—'"></p>
            </div>
          </div>
          <div class="text-sm">
            <span class="text-primary-950/40 dark:text-primary-200/40">Brief</span>
            <p class="font-medium mt-0.5" x-text="brief"></p>
          </div>
        </div>

        <div class="flex justify-between">
          <button type="button" x-on:click="prev()" class="text-sm text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-200 transition">Edit</button>
          <button type="button" x-on:click="next()"
            class="bg-primary-600 dark:bg-primary-400 dark:text-primary-950 text-white hover:bg-primary-700 dark:hover:bg-primary-300 rounded-full px-6 py-3 text-sm font-medium transition">
            Confirm & Pay
          </button>
        </div>
      </div>
    </div>

    <!-- Step 6: Pay -->
    <div
      x-show="step === 6"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="min-h-[100dvh] flex flex-col items-center justify-center px-4 sm:px-6"
    >
      <div class="w-full max-w-md flex flex-col items-center gap-6 text-center">
        <span class="text-xs uppercase tracking-widest text-primary-500 dark:text-primary-400 font-medium">Step 6 of 6</span>
        <h2 class="text-3xl sm:text-4xl font-medium tracking-tight">Complete payment</h2>
        <p class="text-primary-950/60 dark:text-primary-200/60">You'll be redirected to Stripe for secure payment, then receive a booking confirmation by email.</p>

        <a
          :href="stripeLink + '?prefilled_email=' + encodeURIComponent(email) + '&client_reference_id=' + encodeURIComponent(business)"
          x-on:click="
            fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                access_key: '1e0ffadd-2f05-471b-bbc2-36fa32793837',
                subject: 'Discovery Call Booking: ' + selectedName + ' ' + selectedPrice,
                name: name, email: email, business: business,
                website: website, brief: brief,
                call_type: selectedCall, source: 'booking-flow'
              })
            })
          "
          class="bg-primary-600 dark:bg-primary-400 hover:bg-primary-700 dark:hover:bg-primary-300 dark:text-primary-950 inline-flex items-center justify-center rounded-full border border-transparent px-8 py-4 text-base font-medium text-white transition"
        >
          <svg class="mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd"/>
          </svg>
          <span x-text="'Pay ' + selectedPrice + ' & Book'"></span>
        </a>

        <button type="button" x-on:click="prev()" class="text-sm text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-200 transition">Go back</button>

        <p class="text-xs text-primary-950/30 dark:text-primary-200/30 mt-4">Secured by Stripe. Your brief is emailed to me immediately.</p>
      </div>
    </div>

    <!-- Progress dots (fixed bottom) -->
    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40 flex items-center gap-2">
      <template x-for="i in totalSteps" :key="i">
        <button
          type="button"
          x-on:click="if (i < step) step = i"
          :class="step === i ? 'w-6 bg-primary-600 dark:bg-primary-400' : (i < step ? 'w-2 bg-primary-400 dark:bg-primary-500 cursor-pointer' : 'w-2 bg-primary-200 dark:bg-primary-800')"
          class="h-2 rounded-full transition-all duration-300"
        ></button>
      </template>
    </div>

  </div>
</section>
