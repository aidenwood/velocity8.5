<Layout
  description="10 interactive portfolio ideas using creative coding — Three.js, GSAP, Canvas, and WebGL techniques that make your work unforgettable to recruiters and clients."
  title="10 Interactive Portfolio Ideas That Will Make Recruiters Actually Remember You · Blog · Aidxn Design"
>

    <SlotBlog>
      <Fragment slot="category">
        Creative Development — April 2026
      </Fragment>
      <Fragment slot="title">
        10 Interactive Portfolio Ideas That Will Make Recruiters Actually Remember You
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-yellow-500/20 to-pink-500/20 flex items-center justify-center">
          <span class="text-4xl">🚀</span>
