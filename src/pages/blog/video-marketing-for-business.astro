      <Fragment slot="title">
        Let's Talk About What Actually Gets Views in Business Video Marketing
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-red-600/20 to-pink-500/20 flex items-center justify-center">
