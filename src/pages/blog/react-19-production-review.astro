      <Fragment slot="title">
        We've Been Running React 19 in Production for 6 Months — Was It Worth the Upgrade?
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-sky-600/20 to-blue-500/20 flex items-center justify-center">
