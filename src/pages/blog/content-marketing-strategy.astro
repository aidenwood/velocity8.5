<Layout
  description="Content marketing strategy that drives traffic — not just publishing into the void. Blog SEO, distribution, and the content-to-conversion pipeline."
  title="Your Content Marketing Isn't Working Because You're Publishing Into the Void · Blog · Aidxn Design"
>

    <SlotBlog>
      <Fragment slot="category">
        Content Marketing — April 2026
      </Fragment>
      <Fragment slot="title">
        Your Content Marketing Isn't Working Because You're Publishing Into the Void
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-rose-600/20 to-pink-500/20 flex items-center justify-center">
          <span class="text-4xl">&#9997;</span>
