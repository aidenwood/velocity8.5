    <SlotBlog>
      <Fragment slot="category">
        Animation &amp; Motion — April 2026
      </Fragment>
      <Fragment slot="title">
        SVG Animation Techniques That Make Websites Feel Alive
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-emerald-500/20 to-lime-500/20 flex items-center justify-center">
