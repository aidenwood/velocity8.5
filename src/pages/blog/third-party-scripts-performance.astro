      </Fragment>
      <Fragment slot="title">
        That Analytics Script Is Costing You More Than You Think
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-red-600/20 to-orange-500/20 flex items-center justify-center">
