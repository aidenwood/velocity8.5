      <Fragment slot="title">
        WebAssembly Still Hasn't Replaced JavaScript and That's Completely Fine
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-violet-600/20 to-fuchsia-500/20 flex items-center justify-center">
