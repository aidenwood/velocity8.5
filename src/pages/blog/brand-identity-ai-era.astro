>

    <SlotBlog>
      <Fragment slot="category">
        Branding & Strategy — April 2026
      </Fragment>
      <Fragment slot="title">
        When AI Can Generate Anything, Human Design Thinking Matters More Than Ever
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-rose-600/20 to-red-500/20 flex items-center justify-center">
          <span class="text-4xl">✦</span>
