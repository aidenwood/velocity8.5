    <SlotBlog>
      <Fragment slot="category">
        Database Design
      </Fragment>
      <Fragment slot="title">
        The Database Schema Patterns That Saved Us From Ourselves
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-yellow-500/20 to-amber-600/20 flex items-center justify-center">
          <span class="text-4xl">&#128451;</span>
        </div>
