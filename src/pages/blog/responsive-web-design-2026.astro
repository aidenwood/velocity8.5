    <SlotBlog>
      <Fragment slot="category">
        Web Design
      </Fragment>
      <Fragment slot="title">
        Responsive Design Goes Way Beyond Breakpoints Now — Container Queries, Fluid Type, and More
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-violet-600/20 to-cyan-500/20 flex items-center justify-center">
