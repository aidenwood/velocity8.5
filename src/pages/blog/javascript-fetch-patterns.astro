>

    <SlotBlog>
      <Fragment slot="category">
        JavaScript
      </Fragment>
      <Fragment slot="title">
        Everything You Need to Know About fetch() (Including the Parts That Will Bite You)
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-yellow-500/20 to-amber-600/20 flex items-center justify-center">
          <span class="text-4xl">&#127758;</span>
        </div>
