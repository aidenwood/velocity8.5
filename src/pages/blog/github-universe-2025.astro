      <Fragment slot="title">
        GitHub Is Becoming a Full IDE and Nobody's Talking About It
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-gray-600/20 to-purple-500/20 flex items-center justify-center">
