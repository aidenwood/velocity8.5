<Layout
  description="What website maintenance actually includes, what it should cost, and which agencies are charging you for work they are not doing."
  title="What Website Maintenance Actually Means (And What You're Overpaying For) · Blog · Aidxn Design"
>

    <SlotBlog>
      <Fragment slot="category">
        Business Strategy
      </Fragment>
      <Fragment slot="title">
        What Website Maintenance Actually Means (And What You're Overpaying For)
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-slate-500/20 to-gray-600/20 flex items-center justify-center">
          <span class="text-4xl">&#128527;</span>
        </div>
