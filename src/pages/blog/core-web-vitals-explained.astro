<Layout
  description="Core Web Vitals — LCP, INP, and CLS — explained in plain language with practical fixes for each metric. No jargon, just what to actually do."
  title="Core Web Vitals Explained Like You're Actually Going to Fix Them · Blog · Aidxn Design"
>

    <SlotBlog>
      <Fragment slot="category">
        Web Performance & SEO — April 2026
      </Fragment>
      <Fragment slot="title">
        Core Web Vitals Explained Like You're Actually Going to Fix Them
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-green-600/20 to-emerald-500/20 flex items-center justify-center">
