---
import Layout from '../../layouts/Layout.astro';
import { promises as fs } from 'node:fs';
import { fileURLToPath } from 'node:url';
import path from 'node:path';

// Read all .astro blog files and extract titles from the Layout title prop
const blogDir = path.dirname(fileURLToPath(import.meta.url));
const files = await fs.readdir(blogDir);

interface BlogPost {
  url: string;
  title: string;
  subtitle: string;
  category: string;
}

const blogPosts: BlogPost[] = [];

for (const file of files) {
  if (file === 'index.astro' || !file.endsWith('.astro')) continue;

  const slug = file.replace('.astro', '');
  const content = await fs.readFile(path.join(blogDir, file), 'utf-8');

  // Extract title from Layout title="..." prop
  const titleMatch = content.match(/title="([^"]+?)(?:\s*·\s*Blog\s*·\s*Aidxn Design)?"/);
  const creativeTitle = titleMatch?.[1]?.replace(/\s*·\s*Blog\s*·\s*Aidxn Design/, '') || '';

  // Extract category from Fragment slot="category"
  const catMatch = content.match(/slot="category"[^>]*>\s*([^<]+)/);
  const category = catMatch?.[1]?.trim() || 'Blog';

  // Generate plain subtitle from slug
  const subtitle = slug
    .replace(/-/g, ' ')
    .replace(/\b\w/g, (c: string) => c.toUpperCase());

  blogPosts.push({
    url: `/blog/${slug}`,
    title: creativeTitle || subtitle,
    subtitle: creativeTitle ? subtitle : '',
    category,
  });
}

// Sort alphabetically by title for now
blogPosts.sort((a, b) => a.title.localeCompare(b.title));
---

<Layout
  description="Tech news, AI insights, web development tips, and design thinking from Aidxn Design on the Gold Coast."
  title="Blog · Aidxn Design"
>
  <section class="my-20 lg:my-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="font-medium text-4xl tracking-tight sm:text-5xl lg:text-6xl">Blog</h1>
        <p class="mt-4 max-w-2xl text-lg text-primary-600 dark:text-primary-300/70">
          Tech news, AI insights, and web development thinking from the Gold Coast.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {blogPosts.map((post) => (
          <a
            href={post.url}
            class="group flex flex-col rounded-2xl border border-primary-200 dark:border-primary-800/40 bg-white dark:bg-primary-950/40 p-5 transition hover:border-primary-400 dark:hover:border-primary-600/40 hover:shadow-lg dark:hover:bg-primary-950/60"
          >
            <span class="mb-2 text-[11px] font-semibold uppercase tracking-wider text-primary-400 dark:text-primary-500/60">
              {post.category}
            </span>
            <h2 class="text-[15px] font-semibold leading-snug text-primary-950 dark:text-white group-hover:text-violet-600 dark:group-hover:text-violet-400 transition line-clamp-3">
              {post.title}
            </h2>
            {post.subtitle && (
              <p class="mt-1.5 text-[12px] text-primary-500 dark:text-primary-400/50 line-clamp-1">
                {post.subtitle}
              </p>
            )}
            <span class="mt-auto pt-3 inline-flex items-center gap-1 text-[12px] font-medium text-violet-500 dark:text-violet-400/70">
              Read article
              <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
