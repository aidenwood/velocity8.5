---
import Layout from '../../layouts/Layout.astro';

// Get all blog posts from this directory (exclude index)
const posts = await Astro.glob('./*.astro');
const blogPosts = posts
  .filter((p) => !p.url?.endsWith('/blog'))
  .map((p) => ({
    url: p.url,
    title: p.frontmatter?.title || p.url?.split('/').pop()?.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()) || 'Untitled',
  }));
---

<Layout
  description="Tech news, AI insights, web development tips, and design thinking from Aidxn Design on the Gold Coast."
  title="Blog · Aidxn Design"
>
  <section class="my-20 lg:my-28">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="font-medium text-4xl tracking-tight sm:text-5xl lg:text-6xl">Blog</h1>
        <p class="mt-4 max-w-2xl text-lg text-primary-600 dark:text-primary-300/70">
          Tech news, AI insights, and web development thinking from the Gold Coast.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {blogPosts.map((post) => (
          <a
            href={post.url}
            class="group rounded-2xl border border-primary-200 dark:border-primary-800/40 bg-white dark:bg-primary-950/40 p-6 transition hover:border-primary-400 dark:hover:border-primary-600/40 hover:shadow-lg dark:hover:bg-primary-950/60"
          >
            <h2 class="text-lg font-medium text-primary-950 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-300 transition">
              {post.title}
            </h2>
            <span class="mt-3 inline-flex items-center gap-1 text-sm text-primary-500 dark:text-primary-400/60">
              Read more
              <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
