      <Fragment slot="title">
        Wait, JavaScript Is Actually Getting Good? Temporal API, Decorators, and What Shipped in 2025
      </Fragment>

      <Fragment slot="cover">
        <div class="w-full h-48 rounded bg-gradient-to-br from-yellow-500/20 to-orange-600/20 flex items-center justify-center">
